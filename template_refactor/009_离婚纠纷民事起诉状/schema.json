          "type": "group",
          "fields": [
            { "id": "debt_none", "label": "无债务", "type": "checkbox" },
            { "id": "debt_yes", "label": "有债务", "type": "checkbox" },
            { "id": "debt_1", "label": "债务1", "type": "text" },
            { "id": "debt_1_bearer", "label": "承担主体", "type": "radio", "options": ["原告", "被告", "其他"] },
            { "id": "debt_2", "label": "债务2", "type": "text" },
            { "id": "debt_2_bearer", "label": "承担主体", "type": "radio", "options": ["原告", "被告", "其他"] }
          ]
        },
        {
          "id": "claim_4",
          "label": "4. 子女直接抚养",
          "type": "group",
          "fields": [
            { "id": "custody_none", "label": "无此问题", "type": "checkbox" },
            { "id": "custody_yes", "label": "有此问题", "type": "checkbox" },
            { "id": "child_1", "label": "子女1", "type": "text" },
            { "id": "child_1_belong", "label": "归属", "type": "radio", "options": ["原告", "被告"] },
            { "id": "child_2", "label": "子女2", "type": "text" },
            { "id": "child_2_belong", "label": "归属", "type": "radio", "options": ["原告", "被告"] }
          ]
        },
        {
          "id": "claim_5",
          "label": "5. 子女抚养费",
          "type": "group",
          "fields": [
            { "id": "support_none", "label": "无此问题", "type": "checkbox" },
            { "id": "support_yes", "label": "有此问题", "type": "checkbox" },
            { "id": "support_bearer", "label": "抚养费承担主体", "type": "radio", "options": ["原告", "被告"] },
            { "id": "support_amount", "label": "金额及明细", "type": "text" },
            { "id": "support_method", "label": "支付方式", "type": "text" }
          ]
        },
        {
          "id": "claim_6",
          "label": "6. 探望权",
          "type": "group",
          "fields": [
            { "id": "visitation_none", "label": "无此问题", "type": "checkbox" },
            { "id": "visitation_yes", "label": "有此问题", "type": "checkbox" },
            { "id": "visitation_holder", "label": "探望权行使主体", "type": "radio", "options": ["原告", "被告"] },
            { "id": "visitation_method", "label": "行使方式", "type": "text" }
          ]
        },
        {
          "id": "claim_7",
          "label": "7. 离婚损害赔偿 / 离婚经济补偿 / 离婚经济帮助",
          "type": "group",
          "fields": [
            { "id": "claim_7_none", "label": "无此问题", "type": "checkbox" },
            { "id": "claim_7_damage", "label": "离婚损害赔偿", "type": "checkbox" },
            { "id": "claim_7_damage_amount", "label": "金额", "type": "text" },
            { "id": "claim_7_compensation", "label": "离婚经济补偿", "type": "checkbox" },
            { "id": "claim_7_compensation_amount", "label": "金额", "type": "text" },
