        {
          "id": "mediation_benefits",
          "label": "是否了解先行调解解决纠纷的好处",
          "type": "group",
          "fields": [
            { "id": "benefit_1", "label": "1. 立案后选择先行调解", "type": "radio", "options": ["了解", "不了解"] },
            { "id": "benefit_2", "label": "2. 调解成功且自动履行", "type": "radio", "options": ["了解", "不了解"] },
            { "id": "benefit_3", "label": "3. 首次调解不成功", "type": "radio", "options": ["了解", "不了解"] },
            { "id": "benefit_4", "label": "4. 调解具有保密性要求", "type": "radio", "options": ["了解", "不了解"] },
            { "id": "benefit_5", "label": "5. 调解达成的协议具有法律效力", "type": "radio", "options": ["了解", "不了解"] }
          ]
