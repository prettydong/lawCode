        },
        {
          "id": "claim_2",
          "label": "2. 夫妻共同财产",
          "type": "group",
          "fields": [
            { "id": "property_none", "label": "无财产", "type": "checkbox" },
            { "id": "property_yes", "label": "有财产", "type": "checkbox" },
            { "id": "house_detail", "label": "房屋明细", "type": "text" },
